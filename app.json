{
  "expo": {
    "name": "Soprano",
    "slug": "soprano",
    "version": "1.0.1",
    "backgroundColor": "#000000",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "soprano",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": ["audio"]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/icon.png",
        "backgroundImage": "",
        "monochromeImage": ""
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.MODIFY_AUDIO_SETTINGS"],
      "package": "com.climate_op.soprano"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon-16x16.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#000000"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
